<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Employee Registration System</display-name>
    <description>A web application for employee registration using JSP, Servlet and JDBC</description>

    <!-- Welcome file list -->
    <welcome-file-list>
        <welcome-file>EmployeeListServlet</welcome-file>
        <welcome-file>employee-list.jsp</welcome-file>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

    <!-- Session configuration -->
    <session-config>
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
            <secure>false</secure>
        </cookie-config>
    </session-config>

    <!-- Error pages -->
    <error-page>
        <error-code>404</error-code>
        <location>/error-404.jsp</location>
    </error-page>

    <error-page>
        <error-code>500</error-code>
        <location>/error-500.jsp</location>
    </error-page>

    <error-page>
        <exception-type>java.lang.Exception</exception-type>
        <location>/error.jsp</location>
    </error-page>

    <!-- Character encoding filter -->
    <filter>
        <filter-name>CharacterEncodingFilter</filter-name>
        <filter-class>org.apache.catalina.filters.SetCharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
        <init-param>
            <param-name>ignore</param-name>
            <param-value>false</param-value>
        </init-param>
    </filter>

    <filter-mapping>
        <filter-name>CharacterEncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Servlet mappings (if not using annotations) -->
    <!-- 
    <servlet>
        <servlet-name>EmployeeRegistrationServlet</servlet-name>
        <servlet-class>com.employee.controller.EmployeeRegistrationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EmployeeRegistrationServlet</servlet-name>
        <url-pattern>/EmployeeRegistrationServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EmployeeListServlet</servlet-name>
        <servlet-class>com.employee.controller.EmployeeListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EmployeeListServlet</servlet-name>
        <url-pattern>/EmployeeListServlet</url-pattern>
    </servlet-mapping>
    -->

    <!-- Context parameters -->
    <context-param>
        <param-name>db.url</param-name>
        <param-value>jdbc:mysql://localhost:3306/employee_registration</param-value>
    </context-param>

    <context-param>
        <param-name>db.username</param-name>
        <param-value>root</param-value>
    </context-param>

    <context-param>
        <param-name>db.password</param-name>
        <param-value>password</param-value>
    </context-param>

    <!-- Security constraints (optional) -->
    <security-constraint>
        <web-resource-collection>
            <web-resource-name>Admin Pages</web-resource-name>
            <url-pattern>/admin/*</url-pattern>
        </web-resource-collection>
        <auth-constraint>
            <role-name>admin</role-name>
        </auth-constraint>
    </security-constraint>

    <!-- MIME type mappings -->
    <mime-mapping>
        <extension>css</extension>
        <mime-type>text/css</mime-type>
    </mime-mapping>

    <mime-mapping>
        <extension>js</extension>
        <mime-type>application/javascript</mime-type>
    </mime-mapping>

    <!-- JSP configuration -->
    <jsp-config>
        <jsp-property-group>
            <url-pattern>*.jsp</url-pattern>
            <page-encoding>UTF-8</page-encoding>
            <include-prelude>/WEB-INF/jspf/prelude.jspf</include-prelude>
            <include-coda>/WEB-INF/jspf/coda.jspf</include-coda>
        </jsp-property-group>
    </jsp-config>

</web-app>
